{
  "name": "webdock",
  "version": "1.0.0",
  "description": "Your web apps. One dock.",
  "main": "build/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "tsc && npm run copy",
    "copy": "shx mkdir -p build/renderer build/styles build/services && shx cp src/renderer/*.html build/renderer/ && shx cp -r src/styles/* build/styles/ && shx cp -r src/services/* build/services/",
    "watch": "tsc -w",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": "chriz-3656 <chrizmonsaji@proton.me>",
  "homepage": "https://github.com/chriz-3656/webdock",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chriz-3656/webdock.git"
  },
  "license": "MIT",
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "shx": "^0.4.0",
    "typescript": "^5.5.4"
  },
  "keywords": [],
  "bugs": {
    "url": "https://github.com/chriz-3656/webdock/issues"
  }
}
